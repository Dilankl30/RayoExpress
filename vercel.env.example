# Vercel Environment Variables for RayoExpress
# Copy this file to .env and fill in the real values, or set these
# directly in the Vercel Dashboard under Project Settings > Environment Variables.

# Supabase (required for build — Vite inlines VITE_* vars at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only needed for admin-level server-side operations (DO NOT expose publicly)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
