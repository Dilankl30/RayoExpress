# RayoExpress Environment Variables
# Copy this file to .env and fill in your values

# Supabase Project Configuration (get these from your Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Set to true for local development without Supabase
VITE_MOCK_MODE=false

# IMPORTANT SECURITY NOTES:
# - VITE_SUPABASE_ANON_KEY is the public anon key, safe for frontend
# - NEVER put your service_role key in VITE_ variables or the frontend
# - NEVER commit real .env values to the repository
